# Shared
JWT_ACCESS_SECRET=change_access_secret
JWT_REFRESH_SECRET=change_refresh_secret
TOKEN_ISSUER=mdp-system

# PostgreSQL
POSTGRES_DB=mdp_system
POSTGRES_USER=mdp_user
POSTGRES_PASSWORD=mdp_password
POSTGRES_HOST=postgres
POSTGRES_PORT=6543

# Service ports
GATEWAY_PORT=8080
AUTH_SERVICE_PORT=3001
USER_SERVICE_PORT=3002
PROJECT_SERVICE_PORT=3003
ATTENDANCE_SERVICE_PORT=3004
NOTIFICATION_SERVICE_PORT=3005
FRONTEND_PORT=5173

# GPS
GPS_RADIUS_METERS=100

# Google reCAPTCHA
# v2 checkbox mode requires a Challenge (v2) site/secret key pair.
# v3 score mode requires a Score (v3) site/secret key pair.
VITE_RECAPTCHA_SITE_KEY=your_recaptcha_site_key
RECAPTCHA_SECRET_KEY=your_recaptcha_secret_key
RECAPTCHA_MODE=v2_checkbox
RECAPTCHA_ACTION=login
VITE_RECAPTCHA_ACTION=login
RECAPTCHA_MIN_SCORE=0.5
RECAPTCHA_EXPECTED_ACTION=login

# Salary policy
SALARY_HOURLY_RATE=35000
SALARY_STANDARD_HOURS=208
SALARY_OVERTIME_MULTIPLIER=1.5
SALARY_BUSINESS_START_HOUR=8
SALARY_LUNCH_START_HOUR=12
SALARY_LUNCH_END_HOUR=13
SALARY_BUSINESS_END_HOUR=17
# exclude: skip holiday hours | multiplier: apply holiday multiplier from holidays table
SALARY_HOLIDAY_MODE=exclude

# Docker logging
DOCKER_LOG_MAX_SIZE=10m
DOCKER_LOG_MAX_FILE=5
